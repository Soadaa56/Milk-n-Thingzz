<% if @user != nil %>
  <div class='center profile-title'>
    <%= @user.email %>
  </div>
  <% if @user.admin? %>
    <div class='center fs-3 red'>Admin</div>
  <% end %>

  <% if @user.bio != nil %>
    <p class='center fs-4'>
      <%= render 'bio' %>
    </p>
  <% end%>
<% else %>  
  <h1 style='text-decoration: none'>User Not Found</h1>
<% end %>