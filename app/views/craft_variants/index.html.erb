<% if current_user&.admin? %>
  <div class='center mt-4'>
    <div style="font-size: 2rem;">
      Variants of <span><%= link_to @craft.name, craft_path(@craft) %></span>
    </div>
    <div class="mt-3">
      <%= link_to 'All Crafts', crafts_path, class:'btn btn-dark' %>
    </div>
  </div>

  <table class="table table-dark table-hover mt-5" style="font-size: 1em;">
    <thead>
      <tr>
        <th colspan="5" style="font-size: 1.2rem;">Variants</th>
        <th scope="col"><%= link_to 'Add Variant', new_craft_craft_variant_path(@craft.id), class: "btn btn-primary" %></th>
      </tr>
      <tr>
        <th colspan="2" style="font-size: 1.2rem;">Original Craft</th>
        <th scope="col">
          <% if @craft.price %>
            <%= number_to_currency(@craft.price) %>
          <% end %>
          </th>
        <th scope="col"><%= @craft.inventory_count %></th>
        <th scope="col">
          <% if @craft.craft_images.any? && @craft.craft_images.first.image_url(:thumbnail) %>
            <%= image_tag(@craft.craft_images.first.image_url(:thumbnail)) %>
          <% end %>
        </th>
        <th scope="col"></th>
      </tr>
      <tr class="text-decoration-underline" style="font-size: 1.4rem;">
        <th scope=col>ID</th>
        <th scope=col>Name</th>
        <th scope=col>Price</th>
        <th scope=col>Inventory Count</th>
        <th scope=col>Thumbnail</th>
        <th scope="col">Edit</th>
      </tr>
    </thead>
    <tbody>
      <% @craft.craft_variants.each do |cv| %>
      <tr class="fs-5 mb-2">
        <th scope="row"><%= cv.id %></th>
        <td><%= cv.name %></td>
        <td><%= number_to_currency(cv.price) || "N/A" %></td>
        <td><%= cv.inventory_count %></td>
        <td>
          <% if cv.craft_images %>
            <% url = cv.craft_images.first.image_url(:thumbnail) || cv.craft_images.first.image_url %>
            <%= image_tag url, class: "max-thumbnail-size" %>
          <% end %>
        </td>
        <td><%= link_to "Edit Variant", edit_craft_craft_variant_path(@craft.id, cv.id) %></td>
      </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<br><br><br>
<br><br><br>
<%= link_to 'Back', :back, class:'btn btn-custom indent', style: 'margin-left: 5rem' %>

<% console %>