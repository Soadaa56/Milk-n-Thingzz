<% if current_user&.admin? %>
  <h2 class="center mt-5 mt-3">
    Variants of 
    <span>
      <%= link_to @craft.name, craft_path(@craft) %>
    </span>
  </h2>
  <div class='center'>
    <div class="mt-3">
      <%= link_to 'All Crafts', crafts_path, class:'btn btn-dark' %>
    </div>
    <div class="mt-3"><%= link_to 'Add Variant', new_craft_craft_variant_path(@craft.id), class: "btn btn-primary" %></div>
  </div>

  <table class="table table-dark table-hover mt-5">
    <thead>
      <tr>
        <th scope=col>ID</th>
        <th scope=col>Name</th>
        <th scope=col>Price</th>
        <th scope=col>Inventory Count</th>
        <th scope=col>Thumbnail</th>
        <th scope="col">Edit</th>
      </tr>
    </thead>
    <tbody>
      <% @craft.craft_variants.each do |cv| %>
      <tr class="fs-5 mb-2">
        <th scope="row"><%= cv.id %></th>
        <td><%= cv.name %></td>
        <td><%= cv.price %></td>
        <td><%= cv.inventory_count %></td>
        <td></td>
        <td><%= link_to "Edit Variant", edit_craft_craft_variant_path(@craft.id, cv.id) %></td>
      </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
<br><br>
<div class="center">
  <%= link_to 'Add Variant', new_craft_craft_variant_path(@craft.id), class: "btn btn-primary" %>
</div>

<br><br><br>
<br><br><br>
<%= link_to 'Back', :back, class:'btn btn-custom indent', style: 'margin-left: 5rem' %>

<% console %>