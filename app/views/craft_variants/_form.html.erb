<div class="indent large-text edit-craft-form">
  <%= form_with model: [@craft, @craft_variant], local: true, html: { enctype: "multipart/form-data" } do |f| %>

    <% if craft_variant.errors.any? %>
      <div style="color: red">
        <h2>
          <%= pluralize(craft_variant.errors.count, "error") %> prohibited this craft_variant from being saved:
        </h2>
        <ul>
          <% craft_variant.errors.each do |error| %>
          <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="row align-items-start">
      <div class="col">
        <p class="mb-1"><%= raw "&nbsp;" %></p>
        <div class="dark-accent-color mb-5">
          <%= f.label :name, style: "display: block" %>
          <%= f.text_field :name %>
          <p class="light-accent-color mb-5">Name displayed - Such as "Red"</p>
        </div>
        <div class="dark-accent-color mb-5">
          <%= f.label :inventory_count, style: "display: block" %>
          <%= f.number_field :inventory_count %>
          <p class="light-accent-color">Can be 0</p>
        </div>
      </div>
      <div class="col">
        <p class="light-accent-color mb-1">These (below) will overide any defaults on the Craft when selected</p>
        <div class="dark-accent-color">
          <%= f.label :dimensions %>
          <br>
          <%= f.text_area :dimensions, rows: 3, cols: 40 %>
        </div>
        <div class="dark-accent-color">
          <%= f.label :price, style: "display: block" %>
          <%= f.number_field :price, step: "0.01" %>
        </div>
      </div>
    </div>

    <br><br><br>
    <div>
      <label for="files">Upload Image:</label>
      <%= file_field_tag 'files[]', multiple: true %>
      <p class="light-accent-color mb-2">To delete images, check the box next to the image then update craft.</p>
    </div>

    <div class="craft-images-wrapper mb-2">
      <% if craft_variant.craft_images.present? %>
        <%= f.fields_for :craft_images do |ci| %>
          <div class="craft-form-image-card sortable-item">
            <%= image_tag ci.object.image_url(:card) || co.object.image_url %>
            <%= ci.hidden_field :image, value: ci.object.cached_image_data, id: nil %>
            <%= ci.check_box :_destroy %>
            <%= ci.label :_destroy? %>
          </div>
        <% end %>
      <% end %>
    </div>


    <%= f.hidden_field :craft_id, value: @craft.id  %>

    <br><br><br>
    <div>
      <% if @craft_variant.new_record? %>
        <%= f.submit "Create New Craft Variant", class: "btn btn-primary" %>
      <% else %>
        <%= f.submit "Update Craft Variant", class: "btn btn-primary" %>
      <% end %>
    </div>

  <% end %>
</div>